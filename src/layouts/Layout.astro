---
// Components
import Header from "components/Header.astro";
import Footer from "components/Footer.astro";
import Seo from "components/Seo.astro";

// Styles
import "styles/Normalize.scss";
import "styles/Fonts.scss";
import "styles/StyleGuide.scss";
import "styles/Style.scss";
import "styles/Components.scss";
import "styles/Flickity.scss";

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  navDarkMode?: boolean;
  bgNav?: string;
  navBackground?: string;
  pageTransitionName?: string;
  locale?: string;
  footerCta?: {
    title: string;
    text: string;
    buttonText: string;
    buttonLink: string;
    buttonOpenInNewTab?: boolean;
    bulletPoints?: string[];
  };
}

const {
  title,
  description,
  noindex,
  navDarkMode,
  navBackground,
  pageTransitionName,
  locale = "en",
  footerCta,
} = Astro.props;
---

<!doctype html>
<html lang={locale} class="lenis lenis-smooth">
  <head>
    <Seo
      title={title}
      description={description}
      noindex={noindex}
      pageTransitionName={pageTransitionName}
    />
  </head>

  <body
    data-theme-page="light"
    data-navigation-status="not-active"
    data-modal-prelaunch-status="not-active"
    data-modal-status="not-active"
    data-modal-tickets-status="not-active"
    data-nav-filter-status="not-active"
    data-theme-nav={navDarkMode ? "dark" : "light"}
    data-scrolling-started="false"
    data-bg-nav={navBackground}
    data-scrolling-direction="down"
    data-barba="wrapper"
  >
    <Header locale={locale} />

    <main
      id="main"
      class="main"
      data-barba="container"
      data-barba-namespace="home"
      data-page-title={pageTransitionName || "GOSIM"}
    >
      <slot />
    </main>

    <Footer footerCta={footerCta} locale={locale} />

    <script defer src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script
      defer
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
    ></script>
    <script
      defer
      src="https://unpkg.com/flickity@2.3.0/dist/flickity.pkgd.min.js"></script>
    <script
      defer
      src="https://unpkg.com/flickity@2.3.0/dist/flickity.pkgd.min.js"></script>
    <!-- <script defer src="https://cdn.jsdelivr.net/npm/@barba/core@2.9.7"/> -->
    <script
      defer
      src="https://unpkg.com/@studio-freight/lenis@1.0.36/dist/lenis.min.js"
    ></script>
    <script defer src="/js/ScrollTrigger.min.js"></script>
    <script defer src="/js/Animations.js"></script>
    <script is:inline data-locale={locale}>
      // Auto-redirect based on browser language (only on default English pages)
      (function() {
        var el = document.querySelector('script[data-locale]');
        if (!el || el.getAttribute('data-locale') !== 'en') return;
        var stored = document.cookie.match(/(?:^|;\s*)locale=(\w+)/);
        if (stored) return;
        var lang = (navigator.language || '').toLowerCase();
        var path = window.location.pathname.replace(/\/$/, '') || '';
        if (lang.startsWith('zh')) window.location.replace('/zh' + path);
        else if (lang.startsWith('fr')) window.location.replace('/fr' + path);
      })();
    </script>
  </body>
</html>
