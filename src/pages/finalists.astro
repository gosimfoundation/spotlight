---
// Components
import Layout from "layouts/Layout.astro"
import Projects from "components/Projects.astro"
import HeroFinalists from "components/HeroFinalists.astro"
import Intro from "components/Intro.astro"
---

<Layout
  title="GOSIM Spotlight Finalists"
  description="GOSIM Spotlight — where exceptional projects are showcased to the world."
  navDarkMode={true}
  navBackground="header-home"
  pageTransitionName="Home"
>
  <HeroFinalists
    category="Hangzhou",
    date="Sept 13-14, 2025",
    location="Hangzhou, China",
    tagline="Here are the 12 projects selected for the GOSIM Hangzhou Spotlight 2025"
  />
  <Intro>
    <h1 class="h3 light split-words animate-read">
      Congratulations to the 12 projects selected!
      <p></p>
      Come learn about their projects at the spotlight demo booths at <b>
        <a href="https://hangzhou2025.gosim.org/">GOSIM Hangzhou</a>.
      </b>Conference attendees can also listen to their lightning talks on <b
        ><a href="https://hangzhou2025.gosim.org/">Sep 13-14</a></b
      >
    </h1>
  </Intro>
  <Projects />
</Layout>
