---
// Components
import Layout from "layouts/Layout.astro"
import Hero from "components/Hero.astro"
import Intro from "components/Intro.astro"
import Tracks from "components/Tracks.astro"
import Button from "components/Button.astro"
import Timeline from "components/Timeline.astro"
import PreviousEvents from "components/PreviousEvents.astro"
// Images
import GosimDelft from "images/homepage/gosim-delft.png"
import GosimParis2 from "images/homepage/gosim-paris2025.png"
import GosimHangzhou from "images/homepage/gosim-hangzhou.png"
---

<Layout
  title="GOSIM Spotlight 2026: Frontier Creators"
  description="GOSIM Spotlight 2026: Frontier Creators. A platform for those pushing the boundaries of AI and creativity. May 5-6, 2026, Paris, France."
  navDarkMode={true}
  navBackground="header-home"
  pageTransitionName="Home"
  footerCta={{
    title: "Now accepting applications!",
    text: "Know any project that deserves recognition? Don't wait - nominate it today and help us shine a spotlight on its potential. Or apply with your own project. Here are the important dates: Application opens on March 10, 2026, and close on April 10, 2026.",
    buttonText: "Nominate Project",
    buttonLink: "https://cfp.gosim.org/",
    buttonOpenInNewTab: true,
    bulletPoints: [
      "Application period ends: Friday, April 10 at 11:59 PM (UTC - 8)",
      "Selected candidates will be announced by: April 15, 2026",
      "Spotlight Showcase and Lightning Talks: May 5-6, 2026",
    ],
  }}
>
  <Hero
    title="Frontier Creators"
    subtitle="GOSIM Spotlight 2026"
    subtitleAbove
    date="May 5-6, 2026"
    location="Paris, France"
    heroImage="/images/homepage/paris-hero-bk.jpg"
    links={[
      {
        text: "Nominate Project",
        link: "https://cfp.gosim.org/",
        openInNewTab: true,
      },
      {
        text: "Visit GOSIM Paris 2026",
        link: "https://paris2026.gosim.org",
        openInNewTab: true,
      },
    ]}
  />
  <div
    class="section-wrap"
    id="program"
    data-theme-section="light"
    data-bg-section="lightgray"
  >
    <Intro>
      <h1 class="h3 light split-words animate-read">
        Are you building something at the frontier of AI and creativity?
      </h1>
      <h1 class="h5 light split-words animate-read">
        <div style="margin: 1rem 0;"></div>
        Artificial intelligence is transforming how creation happens. At the same time, the boundaries of creators are becoming fluid. Developers, artists, researchers, and entrepreneurs are increasingly building, designing, and experimenting across roles.
        <div style="margin: 1rem 0;"></div>
        <b>GOSIM Spotlight 2026: Frontier Creators</b> is a platform for those pushing these boundaries. We welcome creations in any form — products, systems, code, research, prototypes, or artistic works.
        <div style="margin: 1rem 0;"></div>
        Selected projects will be showcased live in Paris, France, on May 5-6, 2026.
      </h1>
      <br />
      <div style="margin-top: 1.5rem;">
        <Button
          text="Nominate Project"
          link="https://cfp.gosim.org"
          openInNewTab={true}
          class="btn primary xl btn-hover fade-in-last"
        />
      </div>
    </Intro>
  </div>

  <section
    class="section section-guidelines"
    id="guidelines"
    data-theme-section="light"
    data-bg-section="light"
  >
    <div class="container">
      <h2>Submission Guidelines</h2>
      <h1 class="h5 light split-words animate-read" style="text-align: center;">
        Frontier Creators Spotlight is an open call for creative projects exploring the intersection of artificial intelligence and human creativity. We welcome submissions from artists, researchers, developers, designers, and interdisciplinary creators working with AI technologies.
      </h1>

      <div class="guidelines-categories">
        <h3>Accepted Categories</h3>
        <div class="category-tags">
          <span class="category-tag">AI Visual Art</span>
          <span class="category-tag">AI Video</span>
          <span class="category-tag">Interactive Digital Work</span>
          <span class="category-tag">AI Application / Creative Tool</span>
          <span class="category-tag">Interactive Installation</span>
          <span class="category-tag">Physical Installation</span>
          <span class="category-tag">Performance / Live Experience</span>
          <span class="category-tag">Creative Coding Project</span>
          <span class="category-tag">Research-based Creative Project</span>
        </div>
        <p class="guidelines-muted">Hybrid and interdisciplinary works are also welcome.</p>
      </div>

      <div class="guidelines-grid">
        <div class="guideline-card">
          <h3>Submission Requirements</h3>
          <p>Complete the online submission form with:</h4>
          <ul>
            <li><strong>Project information</strong> — title and short description</li>
            <li><strong>AI's role in the creative process</strong> — how AI participates and the contribution of the human creator</li>
            <li><strong>A submission link</strong> to the project materials</li>
          </ul>
          <p>Submit the final work itself along with supporting materials (description, images, demo video, or other documentation). Concept-only submissions without a completed work will not be considered.</p>
          <p>For physical installations, live performances, or software-based works, clear documentation of the final work may be submitted instead.</p>
          <p class="guidelines-muted">Please ensure your link remains accessible until after the event.</p>
        </div>

        <div class="guideline-card">
          <h3>Technical Format Requirements</h3>
          <h4>Images / Visual Works</h4>
          <ul>
            <li>Format: JPG or PNG</li>
            <li>Resolution: at least 1920px on the longer side</li>
          </ul>
          <h4>Video Works</h4>
          <ul>
            <li>Format: MP4 (H.264 recommended)</li>
            <li>Resolution: 1920×1080 (Full HD) or 4K</li>
            <li>Aspect ratio: 16:9</li>
            <li>Preview duration: 2–5 minutes</li>
          </ul>
          <h4>Installation / Interactive / Software</h4>
          <ul>
            <li>Visual documentation (images or video)</li>
            <li>Short project explanation</li>
            <li>Basic information about the work</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div
    class="section-wrap"
    id="how"
    data-theme-section="light"
    data-bg-section="lightgray"
  >
    <Tracks
      title="3 Simple Steps to Participate in GOSIM Spotlight 2026"
      description="Submissions will be reviewed by an independent jury composed of experts from technology, research, art, and entrepreneurship."
      list={[
        {
          title: "Apply or Nominate",
          text: `Tell us about what you are creating and the process behind it. We welcome submissions from all creators, and nominations of others' projects are also encouraged.`,
        },
        {
          title: "Evaluation",
          text: `Our panel of jury reviews the submissions, focusing on innovation, utility, and community impact.`,
        },
        {
          title: "Selection",
          text: `Selected works will be featured on the GOSIM Spotlight 2026 and promoted through our website, newsletter, and social media channels to reach a global audience. Among them, 15-20 creators will be invited to present their work in person at GOSIM Spotlight 2026: Frontier Creators on May 5-6, 2026.`,
        },
      ]}
      ctaButton={{
        text: "Nominate Project",
        link: "https://cfp.gosim.org/",
      }}
    />
  </div>

  <div class="section-wrap" id="timeline">
    <Timeline
      events={[
        {
          date: "March 10, 2026",
          title: "Applications open",
        },
        {
          date: "April 10, 2026",
          title: "Applications close",
        },
        {
          date: "April 15, 2026",
          title: "Candidates announced",
        },
        {
          date: "May 5-6, 2026",
          title: "Spotlight Showcase",
        },
      ]}
    />
  </div>

  <div class="section-wrap" id="previous">
    <PreviousEvents
      title="Previous Spotlight Events"
      events={[
        {
          title: "GOSIM Spotlight 2025: AI for Humanity",
          date: "Hangzhou, China - September 13-14, 2025",
          description:
            "Showcasing groundbreaking AI for Humanity projects exploring how generative AI can foster empathy, shared creativity, and ethical coexistence.",
          image: GosimHangzhou,
          link: "/hangzhou2025",
        },
        {
          title: "GOSIM Spotlight 2025: AI",
          date: "Paris, France - May 6-7, 2025",
          description:
            "Propelling Open-Source AI Forward: Innovative open AI models and robotics projects.",
          image: GosimParis2,
          link: "/paris2025",
        },
        {
          title: "GOSIM Spotlight 2025: Rust",
          date: "Delft, Netherlands - May 13-14, 2025",
          description:
            "Celebrating the brilliance and creativity of open-source projects developed with Rust.",
          image: GosimDelft,
          link: "/delft2025",
        },
      ]}
    />
  </div>

</Layout>

<style>
  :global(.section-home-intro) {
    padding-bottom: calc(var(--section-padding) * 0.4);
  }
  .section-guidelines {
    padding: calc(var(--section-padding) * 0.4) 0;
  }
  :global(.section-how-it-works) {
    padding-top: calc(var(--section-padding) * 0.4);
    padding-bottom: calc(var(--section-padding) * 0.4);
  }
  .section-guidelines h2 {
    text-align: center;
    margin-bottom: 1rem;
  }
  .section-guidelines h3 {
    margin-bottom: 0.5rem;
  }
  .section-guidelines h4 {
    margin-bottom: 0.25rem;
    margin-top: 0.75rem;
  }
  .section-guidelines .h5 {
    max-width: calc(var(--title-size) * 9);
    margin: 0 auto 2rem;
  }
  .guidelines-categories {
    text-align: center;
    margin-bottom: 2rem;
  }
  .category-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
    margin-bottom: 0.5rem;
  }
  .category-tag {
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-dark);
  }
  .guidelines-muted {
    color: rgba(0, 0, 0, 0.4);
    font-style: italic;
  }
  .guidelines-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .guideline-card {
    background: #f5f5f5;
    border-radius: var(--border-radius);
    padding: 1.75rem;
  }
  .guideline-card p {
    margin-bottom: 0.5rem;
  }
  .guideline-card ul {
    list-style: disc;
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .guideline-card li {
    margin-bottom: 0.2rem;
    list-style: disc;
  }
  @media screen and (max-width: 720px) {
    .guidelines-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
