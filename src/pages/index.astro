---
// Components
import Layout from "layouts/Layout.astro"
import Hero from "components/Hero.astro"
import Intro from "components/Intro.astro"
import Cards from "components/Cards.astro"
import Button from "components/Button.astro"
import PreviousEvents from "components/PreviousEvents.astro"
// Images
import GosimDelft from "images/homepage/gosim-delft.png"
import GosimParis2 from "images/homepage/gosim-paris2025.png"
import GosimHangzhou from "images/homepage/gosim-hangzhou.png"
---

<Layout
  title="GOSIM Spotlight"
  description="GOSIM Spotlight: Inspiring the Future Through Open Creation. An international showcase for exceptional open-source projects."
  navDarkMode={true}
  navBackground="header-home"
  pageTransitionName="Home"
  footerCta={{
    title: "Get Involved",
    text: "GOSIM Spotlight is always looking for exceptional open-source projects. Stay tuned for the next call for nominations, or explore our previous spotlight events to see what kind of projects we celebrate.",
    buttonText: "Upcoming Spotlight: Paris 2026",
    buttonLink: "/paris2026",
  }}
>
  <Hero
    subtitle="Inspiring the Future Through Open Creation"
    announcement={{
      text: "Now Open — GOSIM Spotlight 2026: Frontier Creators · Paris, France · May 5-6",
      link: "/paris2026",
    }}
    date=""
    location=""
    links={[
      {
        text: "Upcoming Spotlight",
        link: "/paris2026",
        openInNewTab: false,
      },
      {
        text: "Nominate Project",
        link: "https://cfp.gosim.org/",
        openInNewTab: true,
        highlight: true,
      },
    ]}
  />

  <div
    class="section-wrap"
    id="about"
    data-theme-section="light"
    data-bg-section="lightgray"
  >
    <Intro>
      <h1 class="h3 light split-words animate-read">
        GOSIM Spotlight is an international showcase program that highlights
        exceptional open-source projects, bringing them to the attention of the
        global community.
      </h1>
      <h1 class="h5 light split-words animate-read">
        <div style="margin: 1rem 0;"></div>
        Each edition of GOSIM Spotlight is tied to a major GOSIM conference,
        where selected projects are presented through lightning talks and demo
        booths. Spotlight finalists receive global visibility, mentorship,
        travel support, and the opportunity to connect with leading voices in
        open source, AI, and beyond.
      </h1>
    </Intro>
  </div>

  <div class="section-wrap upcoming-spotlight" id="current">
    <Cards
      title="Upcoming Spotlight"
      description="The next GOSIM Spotlight takes place at GOSIM Paris 2026. We are looking for innovative open-source projects that push boundaries, inspire creativity, and demonstrate real-world impact."
      cards={[
        {
          title: "GOSIM Spotlight 2026: Frontier Creators",
          description:
            "The next edition of GOSIM Spotlight will take place at GOSIM Paris 2026. Details coming soon.",
          image: "/icons/showcase.svg",
        },
      ]}
    />
    <div style="text-align: center; padding-bottom: 4rem;">
      <Button
        text="Upcoming Spotlight: Paris 2026"
        link="/paris2026"
        class="btn primary xl btn-hover"
      />
    </div>
  </div>

  <div class="section-wrap" id="previous">
    <PreviousEvents
      title="Previous Spotlight Events"
      events={[
        {
          title: "GOSIM Spotlight 2025: AIGC",
          date: "Hangzhou, China - September 13-14, 2025",
          description:
            "Showcasing groundbreaking AIGC projects exploring how generative AI can foster empathy, shared creativity, and ethical coexistence.",
          image: GosimHangzhou,
          link: "/hangzhou2025",
        },
        {
          title: "GOSIM Spotlight 2025: AI",
          date: "Paris, France - May 6-7, 2025",
          description:
            "Propelling Open-Source AI Forward: Innovative open AI models and robotics projects.",
          image: GosimParis2,
          link: "/paris2025",
        },
        {
          title: "GOSIM Spotlight 2025: Rust",
          date: "Delft, Netherlands - May 13-14, 2025",
          description:
            "Celebrating the brilliance and creativity of open-source projects developed with Rust.",
          image: GosimDelft,
          link: "/delft2025",
        },
      ]}
    />
  </div>

  <div class="section-wrap" id="why">
    <Cards
      title="Why GOSIM Spotlight?"
      description="GOSIM Spotlight is your launchpad to the world. Selected projects gain international recognition and access to a global network of collaborators, mentors, and opportunities."
      cards={[
        {
          title: "Exclusive Showcase",
          description:
            "Present your project to a curated global audience at major GOSIM conferences.",
          image: "/icons/showcase.svg",
        },
        {
          title: "Travel Support",
          description:
            "Receive travel and accommodation funding for selected representatives to present their work on-site.",
          image: "/icons/travel-support.svg",
        },
        {
          title: "Mentorship & Resources",
          description:
            "Get expert feedback from leading researchers, developers, and industry experts.",
          image: "/icons/mentorship.svg",
        },
        {
          title: "Global Visibility",
          description:
            "Gain recognition at GOSIM conferences and connect with international collaborators and platforms.",
          image: "/icons/global-visibility.svg",
        },
        {
          title: "Networking & Recognition",
          description:
            "Connect with leading voices across open source, AI, Rust, and more.",
          image: "/icons/networking-recognition.svg",
        },
        {
          title: "Community Growth",
          description:
            "Build long-term partnerships and grow within a values-driven open-source ecosystem.",
          image: "/icons/community-growth.svg",
        },
      ]}
    />
  </div>

</Layout>

<style>
  .upcoming-spotlight {
    position: relative;
    background-image: url("/images/homepage/paris-hero-bk.jpg");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .upcoming-spotlight::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.6);
    z-index: 0;
  }

  .upcoming-spotlight > :global(*) {
    position: relative;
    z-index: 1;
  }
</style>
