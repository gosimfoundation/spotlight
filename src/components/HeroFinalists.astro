---
// Components
import Button from "components/Button.astro"

interface Props {
  date?: string
  location?: string
  year?: string
  category?: string
  tagline?: string
  heroImage?: string
  heroVideo?: string
  conferenceName?: string
  conferenceLink?: string
  colocatedText?: string
  links?: Array<{
    text: string
    link: string
    openInNewTab: boolean
  }>
}

const { date, location, year, category, tagline, heroImage, heroVideo, conferenceName, conferenceLink, colocatedText = "Co-located with", links } = Astro.props
---

<section
  class="section section-home-header full-height"
  data-theme-section="dark"
  style="background-color: #616D9C"
  data-bg-section="header-home"
>
  <div class="overlay overlay-background overlay-background-video" style="opacity: 0.9;">
    {heroVideo ? (
      <div class="styled-video playpause overlay">
        <video
          class="overlay video-landscape"
          preload="auto"
          autoplay
          loop
          muted
          webkit-playsinline
          playsinline
          poster={heroImage || ""}
        >
          <source src={heroVideo} type="video/mp4" />
        </video>
      </div>
    ) : heroImage ? (
      <>
        <img src={heroImage} alt="" class="overlay hero-bg-image" />
        <div class="overlay hero-image-tint"></div>
      </>
    ) : (
      <div class="styled-video playpause overlay">
        <video
          class="overlay video-landscape"
          preload="auto"
          autoplay
          loop
          muted
          webkit-playsinline
          playsinline
          poster=""
        >
          <source src="/videos/bg-finalist.webm" type="video/webm" />
          <source src="/videos/bg-finalist.mp4" type="video/mp4" />
        </video>
      </div>
    )}
    <div class="overlay overlay-gradient-v2"></div>
  </div>

  <div class="container">
    <div class="row">
      <div class="col">
        <div class="col col-title">
          <p class="hero-subtitle">GOSIM Spotlight{year ? ` ${year}` : ''}</p>
          <h1>{category}</h1>
        </div>

        {(date || location) && (
          <div class="event-facts">
            {date && <p>{date}</p>}
            {location && <p>{location}</p>}
          </div>
        )}

        {conferenceName && conferenceLink && (
          <div class="co-located">
            <p>{colocatedText} <a href={conferenceLink} target="_blank" rel="noopener noreferrer">{conferenceName}</a></p>
          </div>
        )}

        <div class="finalists">
          {tagline && <p>{tagline}</p>}
        </div>

        <div class="btn-home-wrap">
          {
            links?.map((loop) => (
              <Button
                text={loop.text}
                link={loop.link}
                openInNewTab={loop?.openInNewTab}
                class="btn light xl btn-hover fade-in-last"
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section.full-height .container > .row {
    min-height: 100vh;
  }
  .col-title {
    margin-top: 6%;
  }
  .hero-subtitle {
    font-size: calc(var(--title-size) * 0.3);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 0.25rem;
  }
  .co-located {
    margin-top: 0.5rem;
    font-size: 1.25rem;
    & p {
      color: rgba(255, 255, 255, 0.85);
    }
    & a {
      color: #fff;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    & a:hover {
      opacity: 0.8;
    }
  }
  .finalists {
    max-width: none;
    width: 100%;
    justify-content: center;
    align-items: center;
    position: relative;
    font-size: 1.5rem;
    & > p {
      color: #fff;
      font-weight: 500;
    }
  }
  .hero-bg-image {
    object-fit: cover;
    width: 100%;
    height: 100%;
  }
  .hero-image-tint {
    background: rgba(0, 0, 0, 0.4);
  }
</style>
