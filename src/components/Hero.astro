---
// Components
import Button from "components/Button.astro";

interface Props {
  title?: string;
  subtitle?: string;
  subtitleAbove?: boolean;
  announcement?: {
    text: string;
    link: string;
  };
  date?: string;
  location?: string;
  heroImage?: string;
  heroVideo?: string;
  links?: Array<{
    text: string;
    link: string;
    openInNewTab: boolean;
    highlight?: boolean;
  }>;
}

const { title = "GOSIM Spotlight", subtitle, subtitleAbove = false, announcement, date, location, heroImage, heroVideo, links } = Astro.props;
---

<section
  class="section section-home-header full-height"
  data-theme-section="dark"
  data-bg-section="header-home"
>
  <div class="overlay overlay-background overlay-background-video" style="opacity: 0.9;">
    {heroImage ? (
      <>
        <img src={heroImage} alt="" class="overlay hero-bg-image" />
        <div class="overlay hero-image-tint"></div>
      </>
    ) : (
      <div class="styled-video playpause overlay">
        <video
          class="overlay video-landscape"
          preload="auto"
          autoplay
          loop
          muted
          webkit-playsinline
          playsinline
          poster=""
        >
          {heroVideo ? (
            <source src={heroVideo} type="video/mp4" />
          ) : (
            <>
              <source src="/videos/bg.webm" type="video/webm" />
              <source src="/videos/bg.mp4" type="video/mp4" />
            </>
          )}
        </video>
      </div>
    )}
    <div class="overlay overlay-gradient-v2"></div>
  </div>

  <div class="container">
    <div class="row">
      <div class="col">
        {announcement && (
          <a href={announcement.link} class="announcement-badge">
            <span class="announcement-dot"></span>
            {announcement.text}
            <span class="announcement-arrow">&rarr;</span>
          </a>
        )}
        <div class="col col-title">
          {subtitle && subtitleAbove && <p class="hero-subtitle hero-subtitle-above">{subtitle}</p>}
          <h1>{title}</h1>
          {subtitle && !subtitleAbove && <p class="hero-subtitle">{subtitle}</p>}
        </div>

        {(date || location) && (
          <div class="event-facts">
            {date && <p>{date}</p>}
            {location && <p>{location}</p>}
          </div>
        )}

        <div class="btn-home-wrap">
          {
            links?.map((loop) => (
              <Button
                text={loop.text}
                link={loop.link}
                openInNewTab={loop?.openInNewTab}
                class={loop.highlight ? "btn primary xl btn-hover fade-in-last btn-glow" : "btn light xl btn-hover fade-in-last"}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section.full-height .container > .row {
    min-height: 100vh;
  }

  .announcement-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 999px;
    background: rgba(0, 210, 255, 0.15);
    border: 1px solid rgba(0, 210, 255, 0.5);
    color: white;
    font-size: 1.15rem;
    font-weight: 500;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background 0.2s ease, border-color 0.2s ease;
    margin-bottom: 1rem;
  }
  .announcement-badge:hover {
    background: rgba(0, 210, 255, 0.25);
    border-color: rgba(0, 210, 255, 0.65);
  }
  /* .announcement-dot styled globally in Components.scss */
  .announcement-arrow {
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  .announcement-badge:hover .announcement-arrow {
    opacity: 1;
  }

  .col-title {
    margin-top: 6%;
  }

  .hero-subtitle {
    font-size: calc(var(--title-size) * 0.3);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 0.25rem;
  }
  .hero-subtitle-above {
    margin-top: 0;
    margin-bottom: 0.25rem;
  }

  .hero-bg-image {
    object-fit: cover;
    width: 100%;
    height: 100%;
  }
  .hero-image-tint {
    background: rgba(0, 0, 0, 0.4);
  }

  :global(.btn-glow) {
    animation: glow-pulse 2s ease-in-out infinite;
    box-shadow: 0 0 15px rgba(0, 210, 255, 0.4), 0 0 30px rgba(0, 210, 255, 0.2);
  }

  @keyframes glow-pulse {
    0%, 100% {
      box-shadow: 0 0 15px rgba(0, 210, 255, 0.4), 0 0 30px rgba(0, 210, 255, 0.2);
    }
    50% {
      box-shadow: 0 0 25px rgba(0, 210, 255, 0.6), 0 0 50px rgba(0, 210, 255, 0.3);
    }
  }
</style>
