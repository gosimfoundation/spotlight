---
import Layout from "layouts/Layout.astro"
import HeroFinalists from "components/HeroFinalists.astro"
import Intro from "components/Intro.astro"
import TextAndImage from "components/TextAndImage.astro"
import PreviousEvents from "components/PreviousEvents.astro"
import SpotlightAigc from "images/homepage/spotlight-badge-aigc2025.svg"
import projectsData from "json/Projects-hangzhou2025.json"
import GosimDelft from "images/homepage/gosim-delft.png"
import GosimParis2 from "images/homepage/gosim-paris2025.png"
import GosimHangzhou from "images/homepage/gosim-hangzhou.png"
import { getTranslations, getLocalizedPath, type Locale } from "../i18n/translations"

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = getTranslations(locale);
const projects = projectsData.projects
const numProjs = projects.length
const categories = [...new Set(projects.map((p: any) => p.category).filter(Boolean))]
---

<Layout
  title={t("hangzhou2025.meta.title")}
  description={t("hangzhou2025.meta.desc")}
  navDarkMode={true}
  navBackground="header-home"
  pageTransitionName="Home"
  locale={locale}
>
  <HeroFinalists
    year="2025"
    category="AI for Humanity"
    date={t("hangzhou2025.hero.date")}
    location={t("hangzhou2025.hero.location")}
    heroVideo="/videos/hangzhou2025-hero.mp4"
    heroImage="/images/homepage/gosim-hangzhou-hero.png"
    conferenceName={t("hangzhou2025.conference")}
    conferenceLink="https://hangzhou2025.gosim.org/"
    colocatedText={t("hangzhou2025.colocated")}
    tagline=""
    links={[
      {
        text: t("hangzhou2025.viewProjects"),
        link: "#projects",
        openInNewTab: false,
      },
    ]}
  />
  <div class="confetti-section">
    <div class="confetti-video-wrap">
      <video autoplay loop muted playsinline webkit-playsinline>
        <source src="/videos/confetti.mp4" type="video/mp4" />
      </video>
    </div>
    <Intro>
      <h1 class="h3 light split-words animate-read">
        {t("hangzhou2025.congrats", { count: numProjs })}
        <p></p>
        {t("hangzhou2025.intro")} <b>
          <a href="https://hangzhou2025.gosim.org/">{t("hangzhou2025.conference")}</a>.
        </b> {t("hangzhou2025.talks")} <b>
          {t("hangzhou2025.talksDates")}</b
        >.
      </h1>
    </Intro>
  </div>
  <TextAndImage
    title={t("hangzhou2025.finalists.title")}
    text={t("hangzhou2025.finalists.desc")}
    image={SpotlightAigc}
    imageAlt="Gosim Spotlight badge"
    dataBgSection="beige"
    dataThemeSection="light"
  />
  <section class="section section-finalists" id="projects" data-theme-section="light" data-bg-section="light">
    <div class="container">
      <h2 class="finalists-title">{t("hangzhou2025.finalistsCount", { count: numProjs })}</h2>

      <a href="/docs/gosim-spotlight-2025-ai-for-humanity-finalists.pdf" target="_blank" class="collection-banner">
        <img src="/images/homepage/hangzhou2025-collection-cover.jpg" alt="GOSIM Spotlight 2025: AI for Humanity Collection" />
        <span class="collection-cta">{t("hangzhou2025.viewCollection")}</span>
      </a>

      <div class="filter-tags" id="filter-tags">
        <button class="filter-tag active" data-category="all">{t("hangzhou2025.filterAll")}</button>
        {categories.map((cat: string) => (
          <button class="filter-tag" data-category={cat}>{cat}</button>
        ))}
      </div>

      <div class="finalists-list" id="finalists-list">
        {projects.map((p: any) => (
          <div class="finalist-row" data-category={p.category}>
            <span class="finalist-category">{p.category}</span>
            <span class="finalist-name">{p.title}</span>
            <span class="finalist-author">{p.author}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tags = document.querySelectorAll('.filter-tag');
      const rows = document.querySelectorAll('.finalist-row');
      tags.forEach(tag => {
        tag.addEventListener('click', () => {
          tags.forEach(t => t.classList.remove('active'));
          tag.classList.add('active');
          const cat = tag.getAttribute('data-category');
          rows.forEach(row => {
            if (cat === 'all' || row.getAttribute('data-category') === cat) {
              (row as HTMLElement).style.display = '';
            } else {
              (row as HTMLElement).style.display = 'none';
            }
          });
        });
      });
    });
  </script>

  <div class="section-wrap" id="previous">
    <PreviousEvents
      title={t("previous.title")}
      events={[
        { title: t("previous.hangzhou.title"), date: t("previous.hangzhou.date"), description: t("previous.hangzhou.desc"), image: GosimHangzhou, link: getLocalizedPath("/hangzhou2025", locale) },
        { title: t("previous.paris.title"), date: t("previous.paris.date"), description: t("previous.paris.desc"), image: GosimParis2, link: getLocalizedPath("/paris2025", locale) },
        { title: t("previous.delft.title"), date: t("previous.delft.date"), description: t("previous.delft.desc"), image: GosimDelft, link: getLocalizedPath("/delft2025", locale) },
      ]}
    />
  </div>
</Layout>

<style>
  .section-finalists { padding: var(--section-padding) 0; }
  .finalists-title { text-align: center; margin-bottom: 2rem; }
  .filter-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-bottom: 2rem; }
  .filter-tag { padding: 0.4rem 1rem; border-radius: 999px; border: 1px solid rgba(0,0,0,0.15); background: transparent; font-size: 0.85rem; font-weight: 500; cursor: pointer; transition: all 0.2s ease; color: var(--color-dark); }
  .filter-tag:hover { background: rgba(0,0,0,0.05); }
  .filter-tag.active { background: var(--color-dark); color: white; border-color: var(--color-dark); }
  .finalists-list { display: flex; flex-direction: column; gap: 0; margin-bottom: 3rem; }
  .finalist-row { display: grid; grid-template-columns: 180px 1fr 1fr; gap: 1rem; padding: 0.75rem 1rem; border-bottom: 1px solid rgba(0,0,0,0.08); align-items: center; font-size: 0.9rem; }
  .finalist-row:first-child { border-top: 1px solid rgba(0,0,0,0.08); }
  .finalist-category { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; color: #076597; }
  .finalist-name { font-weight: 500; }
  .finalist-author { color: rgba(0,0,0,0.5); }
  @media screen and (max-width: 720px) { .finalist-row { grid-template-columns: 1fr; gap: 0.25rem; padding: 0.75rem 0.5rem; } }
  .collection-banner { display: block; position: relative; border-radius: var(--border-radius); overflow: hidden; margin-bottom: 2.5rem; text-decoration: none; transition: transform 0.2s ease; }
  .collection-banner:hover { transform: scale(1.005); }
  .collection-banner img { width: 100%; display: block; }
  .collection-cta { position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); color: white; padding: 0.75rem 2rem; border-radius: 999px; font-size: 1.1rem; font-weight: 500; white-space: nowrap; }
</style>
