---
import { locales, localeNames, getLocaleFromUrl, getLocalizedPath } from "../i18n/translations";

const currentLocale = getLocaleFromUrl(Astro.url);
const currentPath = Astro.url.pathname.replace(/^\/(fr|zh)/, "") || "/";
---

<div class="lang-switcher">
  <button class="lang-current" aria-label="Change language">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <path d="M2 12h20"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>
    <span>{localeNames[currentLocale]}</span>
    <svg class="chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="m6 9 6 6 6-6" />
    </svg>
  </button>
  <div class="lang-dropdown">
    {locales.map((locale) => (
      <a
        href={getLocalizedPath(currentPath, locale)}
        class={`lang-option ${locale === currentLocale ? "active" : ""}`}
        data-locale={locale}
      >
        {localeNames[locale]}
      </a>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll(".lang-option").forEach((el) => {
    el.addEventListener("click", () => {
      const locale = (el as HTMLElement).dataset.locale;
      document.cookie = `locale=${locale};path=/;max-age=${60 * 60 * 24 * 365}`;
    });
  });
</script>

<style>
  .lang-switcher {
    position: relative;
    display: flex;
    align-items: center;
  }
  .lang-current {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px;
    padding: 0.4rem 0.65rem;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 600;
    color: #fff;
    font-family: inherit;
    transition: all 0.2s ease;
    letter-spacing: 0.02em;
  }
  .lang-current:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.4);
  }
  /* Light nav theme */
  :global([data-theme-nav="light"]) .lang-current {
    background: rgba(0, 0, 0, 0.05);
    border-color: rgba(0, 0, 0, 0.15);
    color: var(--color-dark, #1a1a2e);
  }
  :global([data-theme-nav="light"]) .lang-current:hover {
    background: rgba(0, 0, 0, 0.1);
    border-color: rgba(0, 0, 0, 0.3);
  }
  /* When nav scrolls and gets light fill */
  :global(.nav-fill-active) .lang-current {
    background: rgba(0, 0, 0, 0.05);
    border-color: rgba(0, 0, 0, 0.15);
    color: var(--color-dark, #1a1a2e);
  }
  .chevron {
    opacity: 0.6;
  }
  .lang-dropdown {
    display: none;
    position: absolute;
    top: calc(100% - 2px);
    right: 0;
    padding-top: 0.4rem;
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    overflow: hidden;
    z-index: 100;
    min-width: 90px;
  }
  .lang-switcher:hover .lang-dropdown,
  .lang-switcher:focus-within .lang-dropdown {
    display: block;
  }
  .lang-option {
    display: block;
    padding: 0.55rem 1rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: #333;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .lang-option:hover {
    background-color: #f0f0f5;
  }
  .lang-option.active {
    color: #076597;
    font-weight: 700;
  }
</style>
